{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "title": "Alarm Configuration",
    "description": "Sending notifications configuration",
    "limited": false,
    "strictProps": false,
    "definitions": {
        "emailRecipient": {
            "title": "E-mail recipient",
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "title": "Type",
                    "enum": ["email"],
                    "default": "email",
                    "options": {
                        "hidden": true
                    },
                    "propertyOrder": 1
                },
                "to": {
                    "type": "string",
                    "title": "E-mail address",
                    "minLength": 1,
                    "propertyOrder": 2
                },
                "subject": {
                    "type": "string",
                    "title": "Subject",
                    "description": "{} will be replaced with alarm message text",
                    "propertyOrder": 3
                }
            },
            "required": ["type", "to"]
        },
        "smsRecipient": {
            "title": "SMS recipient",
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "title": "Type",
                    "enum": ["sms"],
                    "default": "sms",
                    "options": {
                        "hidden": true
                    },
                    "propertyOrder": 1
                },
                "to": {
                    "type": "string",
                    "title": "Phone number",
                    "minLength": 1,
                    "propertyOrder": 2
                },
                "command": {
                    "type": "string",
                    "title": "Command",
                    "propertyOrder": 3
                }
            },
            "required": ["type", "to"]
        },
        "telegramRecipient": {
            "title": "Telegram Bot",
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "title": "Type",
                    "enum": ["telegram"],
                    "default": "telegram",
                    "options": {
                        "hidden": true
                    },
                    "propertyOrder": 1
                },
                "token": {
                    "type": "string",
                    "title": "Bot token",
                    "description": "A token can be obtained from @BotFather",
                    "minLength": 1,
                    "propertyOrder": 2
                },
                "chatId": {
                    "type": "string",
                    "title": "Chat ID",
                    "description": "The chat ID can be obtained from @getidsbot",
                    "propertyOrder": 3
                }
            },
            "required": ["type", "token", "chatId"]
        },
        "vkRecipient": {
            "title": "VK community message",
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "title": "Type",
                    "enum": ["vk"],
                    "default": "vk",
                    "options": {
                        "hidden": true
                    },
                    "propertyOrder": 1
                },
                "token": {
                    "type": "string",
                    "title": "Community access token",
                    "description": "Community access token with `messages` permission, obtained at vk.com/dev",
                    "minLength": 1,
                    "propertyOrder": 2
                },
                "peerId": {
                    "type": "string",
                    "title": "Peer ID",
                    "description": "User ID, or 2000000000 + chat ID for group chats",
                    "minLength": 1,
                    "propertyOrder": 3
                },
                "apiVersion": {
                    "type": "string",
                    "title": "API version",
                    "default": "5.131",
                    "propertyOrder": 4
                }
            },
            "required": ["type", "token", "peerId"]
        },
        "maxRecipient": {
            "title": "MAX messenger bot",
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "title": "Type",
                    "enum": ["max"],
                    "default": "max",
                    "options": {
                        "hidden": true
                    },
                    "propertyOrder": 1
                },
                "token": {
                    "type": "string",
                    "title": "Bot access token",
                    "description": "A token can be obtained from @MasterBot in MAX messenger",
                    "minLength": 1,
                    "propertyOrder": 2
                },
                "chatId": {
                    "type": "string",
                    "title": "Chat ID",
                    "description": "Numeric chat identifier returned by MAX Bot API",
                    "minLength": 1,
                    "propertyOrder": 3
                }
            },
            "required": ["type", "token", "chatId"]
        },
        "matrixRecipient": {
            "title": "Matrix bot",
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "title": "Type",
                    "enum": ["matrix"],
                    "default": "matrix",
                    "options": {
                        "hidden": true
                    },
                    "propertyOrder": 1
                },
                "homeserver": {
                    "type": "string",
                    "title": "Homeserver URL",
                    "description": "Matrix homeserver URL, e.g. https://matrix.org",
                    "minLength": 1,
                    "propertyOrder": 2
                },
                "accessToken": {
                    "type": "string",
                    "title": "Access token",
                    "description": "Bot account access token from POST /_matrix/client/v3/login",
                    "minLength": 1,
                    "propertyOrder": 3
                },
                "roomId": {
                    "type": "string",
                    "title": "Room ID",
                    "description": "Internal room ID like !abcdef:matrix.org (not an alias #room:server)",
                    "minLength": 1,
                    "propertyOrder": 4
                },
                "msgType": {
                    "type": "string",
                    "title": "Message type",
                    "enum": ["m.text", "m.notice"],
                    "default": "m.text",
                    "propertyOrder": 5
                }
            },
            "required": ["type", "homeserver", "accessToken", "roomId"]
        },
        "wechatRecipient": {
            "title": "WeChat Work group bot (NOT regular WeChat)",
            "description": "Corporate WeChat Work (企业微信) only — separate Tencent product, requires organization registration. Does NOT send to regular consumer WeChat (微信).",
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "title": "Type",
                    "enum": ["wechat"],
                    "default": "wechat",
                    "options": {
                        "hidden": true
                    },
                    "propertyOrder": 1
                },
                "key": {
                    "type": "string",
                    "title": "Bot webhook key",
                    "description": "The `key` parameter from the group bot webhook URL in WeChat Work. Created in a WeChat Work group chat via Add Group Robot.",
                    "minLength": 1,
                    "propertyOrder": 2
                }
            },
            "required": ["type", "key"]
        },
        "webhookRecipient": {
            "title": "Generic HTTP webhook",
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "title": "Type",
                    "enum": ["webhook"],
                    "default": "webhook",
                    "options": {
                        "hidden": true
                    },
                    "propertyOrder": 1
                },
                "url": {
                    "type": "string",
                    "title": "URL",
                    "description": "Full request URL including query parameters",
                    "minLength": 1,
                    "propertyOrder": 2
                },
                "method": {
                    "type": "string",
                    "title": "HTTP method",
                    "enum": ["POST", "GET", "PUT", "PATCH", "DELETE"],
                    "default": "POST",
                    "propertyOrder": 3
                },
                "contentType": {
                    "type": "string",
                    "title": "Content-Type",
                    "default": "application/json",
                    "propertyOrder": 4
                },
                "headers": {
                    "type": "object",
                    "title": "Additional headers",
                    "description": "Extra HTTP headers as name/value pairs",
                    "additionalProperties": { "type": "string" },
                    "propertyOrder": 5
                },
                "bodyTemplate": {
                    "type": "string",
                    "title": "Body template",
                    "description": "Request body. {} will be replaced with alarm message text",
                    "propertyOrder": 6
                }
            },
            "required": ["type", "url"]
        },
        "alarmBase": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "title": "Alarm name",
                    "description": "Used as part of the topic",
                    "pattern": "^[^$#+\\/]+$",
                    "minLength": 1,
                    "propertyOrder": 1,
                    "options": {
                        "patternmessage": "Invalid alarm name"
                    }
                },
                "cell": {
                    "type": "string",
                    "title": "Cell",
                    "description": "Use the following format: device/control",
                    "pattern": "^[^\\/\\+#]+/[^\\/\\+#]+$",
                    "minLength": 3,
                    "propertyOrder": 2,
                    "options": {
                        "wb": {
                            "data": "devices"
                        },
                        "patternmessage": "Invalid format"
                    },
                    "format": "wb-autocomplete"
                },
                "alarmMessage": {
                    "type": "string",
                    "title": "Alarm activation message",
                    "description": "{} will be replaced by target cell value",
                    "propertyOrder": 3
                },
                "noAlarmMessage": {
                    "type": "string",
                    "title": "Alarm deactivation message",
                    "description": "{} will be replaced by target cell value",
                    "propertyOrder": 4
                },
                "interval": {
                    "type": "integer",
                    "title": "Alarm interval in seconds",
                    "description": "Alarm messages will be repeated in specified interval while the alarm is active",
                    "minimum": 1,
                    "default": 60,
                    "propertyOrder": 5
                },
                "maxCount": {
                    "type": "integer",
                    "title": "Maximum number of messages",
                    "description": "Maximum number of messages to send while the alarm is active",
                    "propertyOrder": 6
                },
                "alarmDelayMs": {
                    "type": "integer",
                    "title": "Alarm Activation Delay (ms)",
                    "description": "alarmDelayMs_description",
                    "minimum": 0,
                    "default": 0,
                    "propertyOrder": 7
                },
                "noAlarmDelayMs": {
                    "type": "integer",
                    "title": "Alarm Deactivation Delay (ms)",
                    "description": "noAlarmDelayMs_description",
                    "minimum": 0,
                    "default": 0,
                    "propertyOrder": 8
                }
            }
        },
        "minValue": {
            "type": "number",
            "title": "Minimum value",
            "description": "Alarm activates when cell value is less than the minimum value"
        },
        "maxValue": {
            "type": "number",
            "title": "Maximum value",
            "description": "Alarm activates when cell value is greater than the maximum value"
        },
        "expectedValueAlarm": {
            "title": "Expected Value Alarm",
            "defaultProperties": [
                "name",
                "cell",
                "alarmMessage",
                "noAlarmMessage",
                "alarmDelayMs",
                "expectedValue"
            ],
            "allOf": [
                { "$ref": "#/definitions/alarmBase" },
                {
                    "properties": {
                        "expectedValue": {
                            "type": "number",
                            "title": "Expected value",
                            "description": "Alarm activates when cell value differs from the expected value"
                        }
                    },
                    "required": ["name", "cell", "expectedValue"]
                }
            ]
        },
        "minValueAlarm": {
            "title": "Minimum Value Alarm",
            "defaultProperties": [
                "name",
                "cell",
                "alarmMessage",
                "noAlarmMessage",
                "alarmDelayMs",
                "minValue"
            ],
            "allOf": [
                { "$ref": "#/definitions/alarmBase" },
                {
                    "properties": {
                        "minValue": {
                            "$ref": "#/definitions/minValue",
                            "title": "Minimum value",
                            "propertyOrder": 10
                        }
                    },
                    "required": ["name", "cell", "minValue"]
                },
                {
                    "not": {
                        "required": ["maxValue"]
                    }
                }
            ]
        },
        "maxValueAlarm": {
            "title": "Maximum Value Alarm",
            "defaultProperties": [
                "name",
                "cell",
                "alarmMessage",
                "noAlarmMessage",
                "alarmDelayMs",
                "maxValue"
            ],
            "allOf": [
                { "$ref": "#/definitions/alarmBase" },
                {
                    "properties": {
                        "maxValue": {
                            "$ref": "#/definitions/maxValue",
                            "title": "Maximum value",
                            "propertyOrder": 10
                        }
                    },
                    "required": ["name", "cell", "maxValue"]
                },
                {
                    "not": {
                        "required": ["minValue"]
                    }
                }
            ]
        },
        "minMaxValueAlarm": {
            "title": "Minimum&Maximum Value Alarm",
            "defaultProperties": [
                "name",
                "cell",
                "alarmMessage",
                "noAlarmMessage",
                "minValue",
                "maxValue"
            ],
            "allOf": [
                {
                    "$ref": "#/definitions/alarmBase",
                    "title": "Expected value"
                },
                {
                    "properties": {
                        "minValue": {
                            "$ref": "#/definitions/minValue",
                            "title": "Minimum value",
                            "propertyOrder": 10
                        },
                        "maxValue": {
                            "$ref": "#/definitions/maxValue",
                            "title": "Maximum value",
                            "propertyOrder": 11
                        }
                    },
                    "required": ["name", "cell", "minValue", "maxValue"]
                }
            ]
        },
        "recipient": {
            "options": {
                "remove_empty_properties": true,
                "disable_collapse": true,
                "disable_edit_json": true,
                "keep_oneof_values": false
            },
            "title": "Recipient",
            "oneOf": [
                { "$ref": "#/definitions/emailRecipient" },
                { "$ref": "#/definitions/smsRecipient" },
                { "$ref": "#/definitions/telegramRecipient" },
                { "$ref": "#/definitions/vkRecipient" },
                { "$ref": "#/definitions/maxRecipient" },
                { "$ref": "#/definitions/matrixRecipient" },
                { "$ref": "#/definitions/wechatRecipient" },
                { "$ref": "#/definitions/webhookRecipient" }
            ]
        },
        "alarm": {
            "headerTemplate": "Alarm{{: |self.name}}",
            "oneOf": [
                {
                    "$ref": "#/definitions/expectedValueAlarm"
                },
                { "$ref": "#/definitions/minValueAlarm" },
                { "$ref": "#/definitions/maxValueAlarm" },
                { "$ref": "#/definitions/minMaxValueAlarm" }
            ],
            "options": {
                "disable_collapse": true,
                "disable_edit_json": true,
                "remove_empty_properties": false,
                "keep_oneof_values": false
            }
        }
    },
    "properties": {
        "deviceName": {
            "type": "string",
            "title": "Alarm device name",
            "description": "Device name to be used in MQTT topics for logging & alarm cells",
            "pattern": "^[^\\s\\/]+$",
            "minLength": 1,
            "propertyOrder": 1,
            "options": {
                "patternmessage": "Invalid device name"
            }
        },
        "deviceTitle": {
            "type": "string",
            "title": "Alarm device title",
            "description": "Device title to be used in web-interface",
            "propertyOrder": 2
        },
        "recipients": {
            "type": "array",
            "title": "Recipients",
            "items": { "$ref": "#/definitions/recipient" },
            "propertyOrder": 3,
            "options": {
                "disable_array_reorder": true
            }
        },
        "alarms": {
            "type": "array",
            "title": "Alarms",
            "items": { "$ref": "#/definitions/alarm" },
            "propertyOrder": 4,
            "options": {
                "disable_collapse": true,
                "disable_array_reorder": true
            }
        }
    },
    "options": {
        "disable_edit_json": true
    },
    "required": ["deviceName", "recipients", "alarms"],
    "configFile": {
        "path": "/etc/wb-rules/alarms.conf",
        "service": "wb-rules-alarms-reloader"
    },

    "translations": {
        "en": {
            "alarmDelayMs_description": "If set, the alarm condition must be violated for the specified time interval for the alarm to be triggered",
            "noAlarmDelayMs_description": "If set, the alarm condition must be met for the specified time interval for the alarm to be cleared"
        },
